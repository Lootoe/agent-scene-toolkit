{
  "name": "@lilo-agent/core",
  "version": "0.1.0",
  "description": "Lightweight Agent orchestration library built on LangChain, with unified SSE streaming.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "playground": "cd playground && node server.cjs",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-supervisor": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "express": "^4.21.2",
    "langchain": "^1.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/langgraph-supervisor": "^1.0.1",
    "@langchain/openai": "^1.2.12",
    "@types/express": "^5.0.1",
    "express": "^4.21.2",
    "langchain": "^1.0.6",
    "tsup": "^8.5.1",
    "typedoc": "^0.27.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
